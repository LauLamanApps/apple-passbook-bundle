{
    "name": "laulamanapps/apple-passbook-bundle",
    "description": "Generate Apple Wallet passes (PassKit) from your Symfony application",
    "keywords": [
        "apple",
        "passbook",
        "php",
        "wallet",
        "event ticket",
        "coupon",
        "boarding pass",
        "store card",
        "iOS",
        "iPhone",
        "iPod Touch",
        "pkpass"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Laurens Laman",
            "email": "laurens.laman@llaman.nl"
        }
    ],
    "repositories": [
        {
            "type": "path",
            "url": "../apple-passbook",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "LauLamanApps\\ApplePassbookBundle\\": ["src/"]
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LauLamanApps\\ApplePassbookBundle\\Tests\\": ["tests/"]
        }
    },
    "require": {
        "php": "^8.1",
        "laulamanapps/apple-passbook": "2.0.x-dev || ^2.0",
        "ext-openssl": "*",
        "symfony/http-foundation": "^6.4|^7.0|^8.0",
        "symfony/routing": "^6.4|^7.0|^8.0",
        "symfony/event-dispatcher": "^6.4|^7.0|^8.0",
        "symfony/framework-bundle": "^6.4|^7.0|^8.0"
    },
    "require-dev": {
        "symfony/yaml": "^6.4|^7.0|^8.0",
        "symfony/browser-kit": "^6.4|^7.0|^8.0",
        "matthiasnoback/symfony-config-test": "^4.3|^5.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "ext-zip": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "bin-dir": "bin"
    }
}
